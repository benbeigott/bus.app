{
  "buildCommand": "pnpm --filter @workspace/bus-app run build",
  "outputDirectory": "artifacts/bus-app/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
